#!/usr/bin/env bash
# ~/bin/clear-claude [-n] [WINDOW_INDEX]
#
# Inject a literal "/clear" + Enter into a tmux-hosted Claude Code CLI pane so it
# executes as the REAL /clear command. Works around the iOS app's flaky
# slash-command input: trigger by PLAIN LANGUAGE ("clear it") -> Claude runs this
# via Bash, or call it directly / from an SSH-based iOS Shortcut.
#
# The keys queue in the pane's pty and fire when the CLI returns to its prompt
# (i.e. right after the current turn ends), so it's safe to invoke mid-turn.
#
#   -n, --dry-run    resolve + print the target, send nothing
#   WINDOW_INDEX     tmux window index to target (default: 0); pane .0 assumed
#
# Session resolution: the current session if run inside tmux (e.g. Claude's own
# Bash tool), else the first listed session (e.g. an external SSH invocation).
set -eu

dry=0
case "${1:-}" in
    -n|--dry-run) dry=1; shift ;;
esac
win="${1:-0}"

if [ -n "${TMUX:-}" ]; then
    sess=$(tmux display-message -p '#{session_name}')
else
    sess=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | head -n1 || true)
fi
[ -n "${sess:-}" ] || { echo "clear-claude: no tmux session found" >&2; exit 1; }

target="${sess}:${win}.0"
tmux list-panes -t "$target" >/dev/null 2>&1 \
    || { echo "clear-claude: target pane '$target' not found" >&2; exit 1; }

running=$(tmux display-message -p -t "$target" '#{pane_current_command}' 2>/dev/null || echo '?')

if [ "$dry" -eq 1 ]; then
    echo "clear-claude DRY-RUN: would send /clear -> $target (running: $running)"
    exit 0
fi

tmux send-keys -t "$target" '/clear' Enter
echo "clear-claude: sent /clear -> $target (running: $running)"
